{
  "name": "PlayersDatabase",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string"
    },
    "sobrenome": {
      "type": "string"
    },
    "nome_comum": {
      "type": "string"
    },
    "overall": {
      "type": "number"
    },
    "nacionalidade": {
      "type": "string"
    },
    "posicao": {
      "type": "string",
      "enum": [
        "GOL",
        "ZAG",
        "LE",
        "LD",
        "VOL",
        "MC",
        "ME",
        "MD",
        "MEI",
        "PD",
        "PE",
        "SA",
        "ATA"
      ],
      "description": "Posi\u00e7\u00e3o do jogador"
    },
    "salario_base": {
      "type": "number",
      "default": 0
    },
    "valor_base": {
      "type": "number",
      "default": 0
    },
    "multa_rescisoria": {
      "type": "number",
      "default": 0
    },
    "data_nascimento": {
      "type": "string",
      "format": "date"
    },
    "foto_url": {
      "type": "string"
    },
    "team_id": {
      "type": "string"
    },
    "team_nome": {
      "type": "string"
    },
    "league_id": {
      "type": "string"
    },
    "disponivel_venda": {
      "type": "boolean",
      "default": false
    },
    "disponivel_emprestimo": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "nome"
  ]
}