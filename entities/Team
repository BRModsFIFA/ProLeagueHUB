    },
    "player_name": {
      "type": "string"
    },
    "owner_user_id": {
      "type": "string"
    },
    "owner_name": {
      "type": "string"
    },
    "owner_email": {
      "type": "string"
    },
    "owner_display_name": {
      "type": "string"
    },
    "treinador": {
      "type": "string"
    },
    "orcamento": {
      "type": "number",
