{
  "name": "Punishment",
  "type": "object",
  "properties": {
    "team_id": {
      "type": "string"
    },
    "team_nome": {
      "type": "string"
    },
    "league_id": {
      "type": "string"
    },
    "competition_id": {
      "type": "string"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "perda_pontos",
        "multa_financeira",
        "suspensao",
        "outro"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "pontos",
        "financeiro",
        "disciplinar",
        "administrativo"
      ],
      "default": "disciplinar"
    },
    "descricao": {
      "type": "string"
    },
    "pontos_perdidos": {
      "type": "number",
      "default": 0
    },
    "points_delta": {
      "type": "number",
      "default": 0
    },
    "valor_multa": {
      "type": "number",
      "default": 0
    },
    "financial_amount": {
      "type": "number",
      "default": 0
    },
    "rodada": {
      "type": "number"
    },
    "aplicada": {
      "type": "boolean",
      "default": true
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "team_id",
    "tipo"
  ]
}